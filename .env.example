# ── Database ─────────────────────────────────────────────────
# Opciones: sqlite | pgsql
DB_CONNECTION=sqlite
APP_ENV=development

# Solo necesario si DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=document_categorizer
DB_WAIT_TIMEOUT_SECONDS=60

# ── Startup safety ───────────────────────────────────────────
# En produccion, los seeders y migraciones legacy quedan desactivados por defecto.
RUN_STARTUP_SEEDERS=
RUN_STARTUP_LEGACY_MIGRATIONS=
ALLOW_PRODUCTION_ADMIN_SEED=false
ADMIN_SEED_USERS=[]
STARTUP_VALIDATION_MODE=warn
VALIDATE_S3_ON_STARTUP=false
VALIDATE_QUESTIONNAIRE_ANSWERS_ON_STARTUP=true
VALIDATE_TEMPLATE_FILES_ON_STARTUP=true
ALLOW_ALEMBIC_STAMP_ON_EXISTING_SCHEMA=false

# ── App / Auth ───────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
SSO_SECRET_KEY=
JWT_SECRET=

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_BOS_URL=

# ── AWS S3 ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ── Form filling provider matrix ─────────────────────────────
# Opciones: gemini | openai | anthropic
EXTRACTION_PROVIDER=gemini
# Vacio = default del proveedor configurado
EXTRACTION_MODEL=

# Opciones: gemini | openai | anthropic
VERIFICATION_PROVIDER=openai
VERIFICATION_MODEL=gpt-4o-mini

GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Google Gemini / OCR / RAG ────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_ENABLE_EXPLICIT_CACHE=true
GEMINI_CACHE_TTL_SECONDS=3600
GEMINI_CACHE_REFRESH_BUFFER_MS=45000
GEMINI_CACHE_REUSE_LOG_COOLDOWN_MS=60000
GEMINI_LOG_TOKEN_USAGE=true
GEMINI_LOG_TOKEN_DETAILS=false
GEMINI_EMBEDDING_CHAR_ESTIMATE_DIVISOR=4

# Gemini 3 thinking budget. Reduce latencia drasticamente al bajar el nivel.
# Valores: minimal | low | medium | high | off (off=thinking_budget=0, solo Gemini 2.5).
# Vacio en cada por-tarea = hereda GEMINI_THINKING_LEVEL.
GEMINI_THINKING_LEVEL=low
GEMINI_OCR_THINKING_LEVEL=minimal
GEMINI_EXTRACTION_THINKING_LEVEL=low
GEMINI_FORM_DETECTION_THINKING_LEVEL=minimal
GEMINI_VERIFICATION_THINKING_LEVEL=low
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=1024
EMBEDDING_TASK_TYPE_QUERY=RETRIEVAL_QUERY
EMBEDDING_TASK_TYPE_DOCUMENT=RETRIEVAL_DOCUMENT
EMBEDDING_BATCH_SIZE=50
EMBEDDING_MAX_RETRIES=6
EMBEDDING_RETRY_BASE_MS=1200
OCR_CHUNK_SIZE=1200
OCR_CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=12
UPSERT_BATCH_SIZE=30
UPSERT_MAX_RETRIES=5
UPSERT_RETRY_BASE_MS=2000
EVIDENCE_CONTEXT_MAX_CHARS=12000
DB_FALLBACK_MAX_CHARS=30000
PINECONE_API_KEY=
PINECONE_INDEX_OCR=document-categorizer-ocr
PINECONE_NAMESPACE_PREFIX=case
RETRIEVAL_PREFER_SCOPED_DOCUMENT=true
RETRIEVAL_DOCUMENT_FALLBACK_ENABLED=true
VERIFY_TEMPERATURE=0.25
VERIFY_MAX_RETRIES=2

# ── OCR / extraction tuning ──────────────────────────────────
OCR_IMAGE_MAX_LONG_EDGE=1600
OCR_IMAGE_JPEG_QUALITY=80
OCR_REQUEST_TIMEOUT_MS=45000
OCR_REQUEST_MAX_RETRIES=3
OCR_RETRY_BASE_MS=1500
OCR_TEMPERATURE=0.1
OCR_MAX_OUTPUT_TOKENS=16384
FORM_DETECTION_TEMPERATURE=0.1
FORM_DETECTION_MAX_OUTPUT_TOKENS=1024
PAGE_DPI=150
PAGE_IMAGE_QUALITY=85
PAGE_IMAGE_FORMAT=JPEG
EXPORT_PDF_MAX_LONG_EDGE=1600
EXPORT_PDF_JPEG_QUALITY=75
MAX_EXTRACTION_WORKERS=10
EXTRACTION_BATCH_SIZE=10
CASE_EXTRACTION_PARALLEL_BATCHES=3

# ── QC autopilot ─────────────────────────────────────────────
QC_AUTOPILOT_BATCH_USE_PROMPT_CACHE=true
QC_AUTOPILOT_BATCH_MODEL=
QC_AUTOPILOT_BATCH_MAX_OUTPUT_TOKENS=65536
QC_AUTOPILOT_FAST_BATCH_PROMPT=false
QC_AUTOPILOT_EVIDENCE_TOP_K=6
QC_AUTOPILOT_EVIDENCE_MAX_CHARS=12000
QC_AUTOPILOT_EVIDENCE_WORKERS=8
QC_AUTOPILOT_BATCH_SIZE=25
QC_AUTOPILOT_LLM_BATCH_CONCURRENCY=5
QC_AUTOPILOT_SKIP_PREVERIFIED=true
QC_AUTOPILOT_FORCE_BATCH_ON_NO_EVIDENCE=true

# ── Form filling verification agent ──────────────────────────
VERIFICATION_ENABLED=false
VERIFICATION_BATCH_SIZE=20
VERIFICATION_TEMPERATURE=0
VERIFICATION_MAX_TOKENS=4096

# ── Google Document AI ───────────────────────────────────────
GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_DOCUMENT_AI_PROCESSOR_VERSION=

# ── Form filling flags ───────────────────────────────────────
I914_BYPASS_MANUAL_REVIEW=false
