        {
          "id": "p1_1",
          "code": "1",
          "section": "Part 1. Reason for Applying",
          "responsible_party": "client",
          "type": "single_choice",
          "form_text": "I am applying for (select only one box):",
          "instruction": "Replacement (correction) due to USCIS error does not require a new Form I-765 and filing fee. Refer to www.uscis.gov/i-765 for further details.",
          "options": [
            {
              "value": "A",
              "label": "Initial permission to accept employment."
            },
            {
              "value": "B",
              "label": "Replacement of lost, stolen, or damaged previous employment authorization document, or correction of my employment authorization document NOT DUE to U.S. Citizenship and Immigration Services (USCIS) error."
            },
            {
              "value": "C",
              "label": "Renewal of my permission to accept employment. Attach a copy of your previous employment authorization document."
            }
          ],
          "also_validate_with": [
            "attorney"
          ],
          "optional": true,
          "where_to_verify": "BIO CALL; Intake; Declaration"
        },
