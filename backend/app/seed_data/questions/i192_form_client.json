            {
              "value": "B",
              "label": "Admission as a nonimmigrant (other than as a T or U nonimmigrant)."
            }
          ],
          "also_validate_with": [
            "attorney"
          ],
          "optional": true,
          "where_to_verify": "BIO CALL; Intake; Declaration"
        }
      ],
