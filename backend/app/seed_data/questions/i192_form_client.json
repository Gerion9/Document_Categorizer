          "type": "single_choice",
          "form_text": "I am seeking this permission so that I may obtain (select only one box):",
          "options": [
            {
              "value": "A",
              "label": "Status as a victim of trafficking (T nonimmigrant status) or a victim of qualifying criminal activity (U nonimmigrant status)."
